<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:angle="330"
                android:endColor="?attr/colorSurfaceHeroEnd"
                android:startColor="?attr/colorSurfaceHeroStart" />
            <corners android:radius="18dp" />
            <stroke
                android:width="1dp"
                android:color="?attr/colorStrokeStrong" />
        </shape>
    </item>

    <item
        android:gravity="top|end"
        android:width="220dp"
        android:height="220dp"
        android:top="-132dp"
        android:right="-138dp">
        <shape android:shape="rectangle">
            <gradient
                android:centerColor="#081272D8"
                android:centerX="0.72"
                android:centerY="0.22"
                android:endColor="@android:color/transparent"
                android:gradientRadius="180dp"
                android:startColor="#121272D8"
                android:type="radial" />
        </shape>
    </item>
</layer-list>
