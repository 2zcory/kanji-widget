<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:angle="330"
                android:endColor="?attr/colorMainHeroEnd"
                android:startColor="?attr/colorMainHeroStart" />
            <corners android:radius="18dp" />
            <stroke
                android:width="1dp"
                android:color="?attr/colorStrokeStrong" />
        </shape>
    </item>

    <item
        android:gravity="top|end"
        android:width="420dp"
        android:height="320dp"
        android:top="-126dp"
        android:right="-210dp">
        <shape android:shape="rectangle">
            <gradient
                android:centerColor="#081272D8"
                android:centerX="0.88"
                android:centerY="0.12"
                android:endColor="@android:color/transparent"
                android:gradientRadius="250dp"
                android:startColor="?attr/colorMainHeroGlow"
                android:type="radial" />
        </shape>
    </item>
</layer-list>
