<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rankingItemRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:background="@drawable/bg_detail_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <TextView
        android:id="@+id/tvRankingKanji"
        android:layout_width="56dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="#231D16"
        android:textSize="28sp"
        android:textStyle="bold"
        tools:text="日" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvRankingPrimary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:textColor="#231D16"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Sun" />

        <TextView
            android:id="@+id/tvRankingSecondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:maxLines="2"
            android:textColor="#6D6050"
            android:textSize="12sp"
            tools:text="JLPT N5 • Today" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvRankingDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:textColor="#A1482E"
        android:textSize="13sp"
        android:textStyle="bold"
        tools:text="2 min" />

</LinearLayout>
