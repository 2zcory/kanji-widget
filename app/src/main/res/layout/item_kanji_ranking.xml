<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rankingItemRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:background="@drawable/bg_detail_panel"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <TextView
        android:id="@+id/tvRankingKanji"
        android:layout_width="48dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="?attr/colorTextPrimary"
        android:textSize="28sp"
        android:textStyle="bold"
        tools:text="日" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvRankingPrimary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="?attr/colorTextPrimary"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Sun" />

        <TextView
            android:id="@+id/tvRankingSecondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="?attr/colorTextMuted"
            android:textSize="12sp"
            tools:text="JLPT N5 • Today" />

        <TextView
            android:id="@+id/tvRankingMetricCaption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:maxLines="1"
            android:textColor="?attr/colorTextSecondary"
            android:textSize="11sp"
            android:textStyle="bold"
            tools:text="36 seconds studied" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:gravity="center_vertical"
        android:text="@string/home_recent_chevron"
        android:textColor="?attr/colorTextMuted"
        android:textSize="16sp"
        tools:ignore="HardcodedText" />

</LinearLayout>
