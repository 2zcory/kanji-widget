<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_study_stats_sheet"
    android:orientation="vertical"
    android:padding="18dp">

    <View
        android:layout_width="42dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_chart_drag_handle" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/chart_title"
        android:textColor="#231D16"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvChartRangeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="#6D6050"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnChartRange7"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginRight="6dp"
            android:layout_weight="1"
            android:text="@string/chart_range_7"
            android:textAllCaps="false"
            android:textColor="#231D16" />

        <Button
            android:id="@+id/btnChartRange30"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="6dp"
            android:layout_weight="1"
            android:text="@string/chart_range_30"
            android:textAllCaps="false"
            android:textColor="#231D16" />
    </LinearLayout>

    <com.example.kanjiwidget.stats.StudyTimeChartView
        android:id="@+id/studyTimeChartView"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_detail_canvas"
        android:padding="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_detail_card"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvChartTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#231D16"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvChartAverage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#3F3529"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvChartBestDay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#3F3529"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvChartLatestKanji"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#6D6050"
            android:textSize="13sp" />
    </LinearLayout>

</LinearLayout>
