<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_study_stats_sheet"
        android:orientation="vertical"
        android:padding="18dp">

    <View
        android:layout_width="42dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_chart_drag_handle" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/chart_title"
        android:textColor="#231D16"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvChartRangeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="#6D6050"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnChartRange7"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginRight="6dp"
            android:layout_weight="1"
            android:text="@string/chart_range_7"
            android:textAllCaps="false"
            android:textColor="#231D16" />

        <Button
            android:id="@+id/btnChartRange30"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="6dp"
            android:layout_weight="1"
            android:text="@string/chart_range_30"
            android:textAllCaps="false"
            android:textColor="#231D16" />
    </LinearLayout>

    <com.example.kanjiwidget.stats.StudyTimeChartView
        android:id="@+id/studyTimeChartView"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_detail_canvas"
        android:padding="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_detail_card"
            android:orientation="vertical"
            android:padding="14dp">

        <TextView
            android:id="@+id/tvChartTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#231D16"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvChartAverage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#3F3529"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvChartBestDay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#3F3529"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvChartLatestKanji"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#6D6050"
            android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_detail_card"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ranking_title"
                android:textColor="#231D16"
                android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnRankingScopeAll"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="6dp"
                    android:layout_weight="1"
                    android:text="@string/ranking_scope_all"
                    android:textAllCaps="false"
                    android:textColor="#231D16" />

                <Button
                    android:id="@+id/btnRankingScope30"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="6dp"
                    android:layout_weight="1"
                    android:text="@string/ranking_scope_30"
                    android:textAllCaps="false"
                    android:textColor="#231D16" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvRankingMostTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/ranking_most_title"
                android:textColor="#A1482E"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/containerRankingMost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/tvRankingLeastTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/ranking_least_title"
                android:textColor="#A1482E"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/containerRankingLeast"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/tvRankingEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/ranking_empty"
                android:textColor="#6D6050"
                android:textSize="13sp"
                android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>
