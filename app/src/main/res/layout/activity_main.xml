<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F1E8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_detail_hero"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_title"
                android:textColor="#1A1510"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvWidgetStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_detail_badge"
                android:paddingLeft="10dp"
                android:paddingTop="6dp"
                android:paddingRight="10dp"
                android:paddingBottom="6dp"
                android:textColor="#FFF9F0"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/home_subtitle"
                android:textColor="#5D5040"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_detail_card"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/tvHomeSummaryTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#A1482E"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvHomeSummarySubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#231D16"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvHomeSummaryMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="#6D6050"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sectionContinueLearning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_detail_card"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_continue_title"
                android:textColor="#A1482E"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvContinueLearningBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#3F3529"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnOpenLatestKanji"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="7dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_detail_button"
                    android:text="@string/home_action_open_latest"
                    android:textAllCaps="false"
                    android:textColor="#FFF9F0" />

                <Button
                    android:id="@+id/btnOpenRandomKanji"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="7dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_detail_button"
                    android:text="@string/home_action_open_random"
                    android:textAllCaps="false"
                    android:textColor="#FFF9F0" />
            </LinearLayout>

            <Button
                android:id="@+id/btnTodayStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_detail_button"
                android:text="@string/home_action_today_stats"
                android:textAllCaps="false"
                android:textColor="#FFF9F0" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sectionRecentKanji"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_detail_card"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_recent_title"
                android:textColor="#A1482E"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRecentKanjiBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/home_recent_body"
                android:textColor="#6D6050"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/containerRecentKanji"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sectionWidgetControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_detail_card"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_widget_controls_title"
                android:textColor="#A1482E"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvWidgetControlsBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#3F3529"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvWidgetOpacityValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="#231D16"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/home_widget_opacity_body"
                android:textColor="#6D6050"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnWidgetOpacity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_detail_button"
                android:text="@string/home_action_widget_opacity"
                android:textAllCaps="false"
                android:textColor="#FFF9F0" />

            <Button
                android:id="@+id/btnWidgetHelp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_detail_button"
                android:text="@string/home_action_widget_help"
                android:textAllCaps="false"
                android:textColor="#FFF9F0" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sectionLanguage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_detail_card"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/language_section_title"
                android:textColor="#A1482E"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvLanguageBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/language_section_body"
                android:textColor="#3F3529"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvLanguageValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="#231D16"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnLanguage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_detail_button"
                android:text="@string/language_action_change"
                android:textAllCaps="false"
                android:textColor="#FFF9F0" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
