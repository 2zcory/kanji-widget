<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dialogLanguageOverlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#140A1622"
    android:foregroundGravity="center"
    android:padding="16dp"
    tools:ignore="Overdraw">

    <LinearLayout
        android:id="@+id/dialogLanguageRoot"
        android:layout_width="340dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_dialog_surface"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/tvLanguageDialogTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/language_dialog_title"
            android:textColor="?attr/colorTextPrimary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvLanguageDialogBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/language_section_body"
            android:textColor="?attr/colorTextMuted"
            android:textSize="13sp" />

        <RadioGroup
            android:id="@+id/groupLanguageOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="end"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnLanguageDialogCancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_detail_button_secondary"
                android:minWidth="0dp"
                android:paddingLeft="16dp"
                android:paddingTop="8dp"
                android:paddingRight="16dp"
                android:paddingBottom="8dp"
                android:text="@android:string/cancel"
                android:textAllCaps="false"
                android:textColor="?attr/colorSecondaryButtonText"
                tools:ignore="ButtonStyle" />

            <Button
                android:id="@+id/btnLanguageDialogApply"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_detail_button"
                android:minWidth="0dp"
                android:paddingLeft="16dp"
                android:paddingTop="8dp"
                android:paddingRight="16dp"
                android:paddingBottom="8dp"
                android:text="@string/language_action_apply"
                android:textAllCaps="false"
                android:textColor="?attr/colorPrimaryButtonText"
                tools:ignore="ButtonStyle" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
