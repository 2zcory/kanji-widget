<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_detail_hero"
            android:elevation="12dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/tvWidgetConfigTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvWidgetConfigBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_detail_card"
            android:elevation="10dp"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_config_opacity_title"
                android:textColor="?attr/colorAccentWarm"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvWidgetConfigSelectionValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/widget_config_opacity_body"
                android:textColor="?attr/colorTextMuted"
                android:textSize="13sp" />

            <RadioGroup
                android:id="@+id/groupWidgetOpacityPresets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical" />
        </LinearLayout>

        <Button
            android:id="@+id/btnWidgetConfigSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_detail_button"
            android:elevation="10dp"
            android:text="@string/widget_config_action_add"
            android:textAllCaps="false"
            android:textColor="?attr/colorPrimaryButtonText" />

        <Button
            android:id="@+id/btnWidgetConfigCancel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_detail_button_secondary"
            android:elevation="8dp"
            android:text="@string/widget_config_action_cancel"
            android:textAllCaps="false"
            android:textColor="?attr/colorSecondaryButtonText" />

    </LinearLayout>
</ScrollView>
