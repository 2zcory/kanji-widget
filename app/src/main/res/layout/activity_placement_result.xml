<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_screen_surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/sectionPlacementResultHero"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_main_hero_surface"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnPlacementResultBack"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_icon_button"
                    android:contentDescription="@string/placement_action_back"
                    android:padding="9dp"
                    android:src="@drawable/ic_arrow_back_kw"
                    android:tint="?attr/colorTextPrimary" />

                <TextView
                    android:id="@+id/tvPlacementResultHeroLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:textColor="?attr/colorAccentWarm"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textAllCaps="true" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvPlacementResultHeroTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPlacementResultHeroBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="15sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvPlacementResultMetaPrimary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_home_meta_pill"
                    android:paddingLeft="10dp"
                    android:paddingTop="6dp"
                    android:paddingRight="10dp"
                    android:paddingBottom="6dp"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPlacementResultMetaSecondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_home_meta_pill"
                    android:paddingLeft="10dp"
                    android:paddingTop="6dp"
                    android:paddingRight="10dp"
                    android:paddingBottom="6dp"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sectionPlacementResultSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_main_section_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/tvPlacementResultScore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPlacementResultRationale"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="15sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/placement_result_guidance_note"
                android:textColor="?attr/colorTextMuted"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnPlacementResultOpenRoadmap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_main_primary_button"
                android:minHeight="48dp"
                android:text="@string/placement_result_action_open_roadmap"
                android:textAllCaps="false"
                android:textColor="?attr/colorPrimaryButtonText"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnPlacementResultStartBatch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_home_action_chip"
                android:minHeight="48dp"
                android:text="@string/placement_result_action_start_batch"
                android:textAllCaps="false"
                android:textColor="?attr/colorSecondaryButtonText"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
