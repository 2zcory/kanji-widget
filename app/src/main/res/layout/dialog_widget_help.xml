<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dialogWidgetHelpOverlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#140A1622"
    android:foregroundGravity="center"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/dialogWidgetHelpRoot"
        android:layout_width="340dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_dialog_surface"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/tvWidgetHelpTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/home_widget_help_title"
            android:textColor="?attr/colorTextPrimary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvWidgetHelpBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/home_widget_help_dialog_message"
            android:textColor="?attr/colorTextSecondary"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnWidgetHelpClose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_detail_button"
            android:minWidth="0dp"
            android:paddingLeft="16dp"
            android:paddingTop="8dp"
            android:paddingRight="16dp"
            android:paddingBottom="8dp"
            android:text="@android:string/ok"
            android:textAllCaps="false"
            android:textColor="?attr/colorPrimaryButtonText" />
    </LinearLayout>
</FrameLayout>
