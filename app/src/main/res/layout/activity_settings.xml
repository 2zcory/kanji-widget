<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/sectionSettingsHero"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_detail_hero"
            android:orientation="vertical"
            android:padding="18dp">

            <Button
                android:id="@+id/btnSettingsBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_detail_button"
                android:text="@string/settings_action_back"
                android:textAllCaps="false"
                android:textColor="?attr/colorPrimaryButtonText" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/settings_section_label"
                android:textColor="?attr/colorAccentWarm"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/settings_title"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_subtitle"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sectionSettingsWidgetControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_detail_card"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_widget_controls_title"
                android:textColor="?attr/colorAccentWarm"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSettingsWidgetControlsBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvSettingsWidgetOpacityValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/home_widget_opacity_body"
                android:textColor="?attr/colorTextMuted"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnSettingsWidgetOpacity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_detail_button"
                android:text="@string/home_action_widget_opacity"
                android:textAllCaps="false"
                android:textColor="?attr/colorPrimaryButtonText" />

            <Button
                android:id="@+id/btnSettingsWidgetHelp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_detail_button"
                android:text="@string/home_action_widget_help"
                android:textAllCaps="false"
                android:textColor="?attr/colorPrimaryButtonText" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sectionSettingsTheme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_detail_card"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/theme_section_title"
                android:textColor="?attr/colorAccentWarm"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/theme_section_body"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvSettingsThemeValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnSettingsTheme"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_detail_button"
                android:text="@string/theme_action_change"
                android:textAllCaps="false"
                android:textColor="?attr/colorPrimaryButtonText" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sectionSettingsLanguage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_detail_card"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/language_section_title"
                android:textColor="?attr/colorAccentWarm"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/language_section_body"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvSettingsLanguageValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="?attr/colorTextPrimary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnSettingsLanguage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_detail_button"
                android:text="@string/language_action_change"
                android:textAllCaps="false"
                android:textColor="?attr/colorPrimaryButtonText" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
