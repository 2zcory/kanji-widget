<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/sectionSettingsTopBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="start|center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnSettingsBack"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_icon_button"
                android:contentDescription="@string/settings_action_back"
                android:padding="9dp"
                app:srcCompat="@drawable/ic_arrow_back_kw"
                app:tint="?attr/colorTextPrimary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sectionSettingsTheme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_detail_card"
            android:orientation="vertical"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_theme_title"
                    android:textColor="?attr/colorTextPrimary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_theme_count"
                    android:textColor="?attr/colorAccentMain"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/settings_theme_body"
                android:textColor="?attr/colorTextSecondary"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/tileThemeSystem"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_settings_tile"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <View
                        android:id="@+id/previewThemeSystem"
                        android:layout_width="match_parent"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_theme_preview_system" />

                    <TextView
                        android:id="@+id/tvThemeSystemTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/theme_option_system"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvThemeSystemBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/settings_theme_option_system_body"
                        android:textColor="?attr/colorTextMuted"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tileThemeLight"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_settings_tile"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <View
                        android:id="@+id/previewThemeLight"
                        android:layout_width="match_parent"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_theme_preview_light" />

                    <TextView
                        android:id="@+id/tvThemeLightTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/theme_option_light"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvThemeLightBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/settings_theme_option_light_body"
                        android:textColor="?attr/colorTextMuted"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/tileThemeDark"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_settings_tile"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <View
                        android:id="@+id/previewThemeDark"
                        android:layout_width="match_parent"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_theme_preview_dark" />

                    <TextView
                        android:id="@+id/tvThemeDarkTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/theme_option_dark"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvThemeDarkBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/settings_theme_option_dark_body"
                        android:textColor="?attr/colorTextMuted"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tileThemeGlass"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_settings_tile"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <View
                        android:id="@+id/previewThemeGlass"
                        android:layout_width="match_parent"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_theme_preview_glass" />

                    <TextView
                        android:id="@+id/tvThemeGlassTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/theme_option_glass"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvThemeGlassBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/settings_theme_option_glass_body"
                        android:textColor="?attr/colorTextMuted"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sectionSettingsUtilityStack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_detail_card"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:id="@+id/sectionSettingsWidgetControls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_detail_panel"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_widget_opacity_title"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_widget_opacity_direct_control"
                        android:textColor="?attr/colorAccentMain"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvSettingsWidgetControlsBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="?attr/colorTextSecondary"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:baselineAligned="false"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_widget_opacity_caption"
                        android:textColor="?attr/colorTextMuted"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSettingsWidgetOpacityValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekSettingsWidgetOpacity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:max="60"
                    android:progressDrawable="@drawable/bg_settings_slider_track"
                    android:splitTrack="false"
                    android:thumb="@drawable/bg_settings_slider_thumb" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/home_widget_opacity_body"
                    android:textColor="?attr/colorTextMuted"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowSettingsLanguage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_settings_row"
                android:baselineAligned="false"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:minHeight="68dp"
                android:orientation="horizontal"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/language_section_title"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSettingsLanguageValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="?attr/colorTextSecondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    app:srcCompat="@drawable/ic_chevron_right_kw"
                    app:tint="?attr/colorTextMuted" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowSettingsWidgetHelp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_settings_row"
                android:baselineAligned="false"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:minHeight="68dp"
                android:orientation="horizontal"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_action_widget_help"
                        android:textColor="?attr/colorTextPrimary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSettingsWidgetHelpBody"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/settings_widget_help_body"
                        android:textColor="?attr/colorTextSecondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    app:srcCompat="@drawable/ic_chevron_right_kw"
                    app:tint="?attr/colorTextMuted" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
