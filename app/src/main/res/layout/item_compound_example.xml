<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tvCompoundWritten"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#231D16"
        android:textSize="20sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvCompoundReading"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#6D6050"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnPlayCompoundReading"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_chart_range_idle"
            android:contentDescription="@string/detail_audio_play_content_description"
            android:padding="8dp"
            android:src="@android:drawable/ic_lock_silent_mode_off"
            android:tint="#231D16" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvCompoundMeaning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="#3F3529"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/tvCompoundUsage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="#A1482E"
        android:textSize="12sp"
        android:textStyle="bold" />
</LinearLayout>
