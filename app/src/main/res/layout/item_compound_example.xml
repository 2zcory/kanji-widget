<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/compoundExampleRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    android:background="@drawable/bg_detail_panel"
    android:gravity="center_vertical"
    android:minHeight="82dp"
    android:orientation="horizontal"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvCompoundWritten"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorTextPrimary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCompoundSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="?attr/colorTextSecondary"
            android:textSize="14sp" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnPlayCompoundReading"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginStart="12dp"
        android:background="@drawable/bg_icon_button"
        android:contentDescription="@string/detail_audio_play_content_description"
        android:padding="7dp"
        app:srcCompat="@drawable/ic_speaker_kw"
        app:tint="?attr/colorTextPrimary" />
</LinearLayout>
