<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widgetContent"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/widgetBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="fitXY"
        android:src="@drawable/bg_widget_surface" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvJlpt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_widget_pill_primary"
                android:gravity="center"
                android:maxLines="1"
                android:minHeight="28dp"
                android:paddingLeft="10dp"
                android:paddingTop="5dp"
                android:paddingRight="10dp"
                android:paddingBottom="5dp"
                android:text="@string/jlpt_placeholder"
                android:textColor="#0E72D2"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="JLPT N5" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_widget_pill_hidden"
                android:gravity="center"
                android:maxLines="1"
                android:minHeight="28dp"
                android:paddingLeft="10dp"
                android:paddingTop="5dp"
                android:paddingRight="10dp"
                android:paddingBottom="5dp"
                android:text="@string/widget_state_hidden"
                android:textColor="#5B6A7D"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="Hidden" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1"
            android:baselineAligned="false"
            android:orientation="horizontal"
            tools:ignore="NestedWeights">

            <TextView
                android:id="@+id/tvKanji"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="10dp"
                android:layout_weight="0.42"
                android:background="@drawable/bg_widget_hero"
                android:fontFamily="@font/kanji_stroke_order"
                android:gravity="center"
                android:maxLines="1"
                android:paddingLeft="12dp"
                android:paddingTop="12dp"
                android:paddingRight="12dp"
                android:paddingBottom="12dp"
                android:text="@string/widget_placeholder_kanji"
                android:textColor="#102740"
                android:textSize="66sp"
                android:textStyle="bold"
                tools:text="日" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.58"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvReading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_widget_info_card"
                    android:ellipsize="end"
                    android:maxLines="3"
                    android:minHeight="54dp"
                    android:paddingLeft="12dp"
                    android:paddingTop="11dp"
                    android:paddingRight="12dp"
                    android:paddingBottom="11dp"
                    android:text="@string/widget_placeholder_reading"
                    android:textColor="#233A56"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="On: ニチ&#10;Kun: ひ" />

                <TextView
                    android:id="@+id/tvMeaning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_widget_info_card"
                    android:ellipsize="end"
                    android:maxLines="3"
                    android:minHeight="54dp"
                    android:paddingLeft="12dp"
                    android:paddingTop="11dp"
                    android:paddingRight="12dp"
                    android:paddingBottom="11dp"
                    android:text="@string/widget_placeholder_meaning"
                    android:textColor="#52687D"
                    android:textSize="14sp"
                    tools:text="Sun, day" />

                <TextView
                    android:id="@+id/tvExample"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_widget_info_card"
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:maxLines="3"
                    android:minHeight="56dp"
                    android:paddingLeft="12dp"
                    android:paddingTop="11dp"
                    android:paddingRight="12dp"
                    android:paddingBottom="11dp"
                    android:text="@string/widget_placeholder_example"
                    android:textColor="#627488"
                    android:textSize="13sp"
                    android:visibility="gone"
                    tools:text="U+65E5 • Source: kanjiapi.dev" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/widget_meta_catalog_loading"
            android:textColor="#647487"
            android:textSize="12sp"
            tools:text="Catalog: 2,136 kanji • Source: cache • 3 hours ago" />

        <Button
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_widget_action"
            android:maxLines="1"
            android:minHeight="42dp"
            android:text="@string/widget_action_reveal"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="Reveal answer" />

    </LinearLayout>

</FrameLayout>
