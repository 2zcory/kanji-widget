<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#F7F4EE">

    <TextView
        android:id="@+id/tvKanji"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="日"
        android:textSize="40sp"
        android:textStyle="bold"
        android:fontFamily="@font/kanji_stroke_order"
        android:textColor="#1B1B1B" />

    <TextView
        android:id="@+id/tvJlpt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="JLPT N5"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#8A5A00" />

    <TextView
        android:id="@+id/tvReading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="ニチ / ひ"
        android:textSize="14sp"
        android:textColor="#333333" />

    <TextView
        android:id="@+id/tvMeaning"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Mặt trời, ngày"
        android:textSize="14sp"
        android:textColor="#333333" />

    <TextView
        android:id="@+id/tvExample"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="日本（にほん）"
        android:textSize="13sp"
        android:textColor="#555555" />

    <Button
        android:id="@+id/btnNext"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Đổi chữ"
        android:textAllCaps="false" />

</LinearLayout>
